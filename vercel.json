{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.medicalequipment.africa" }],
      "destination": "https://medicalequipment.africa/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
